<?xml version="1.0"?>
<!-- 使用了Xacro 宏定义 -->
<robot xmlns:xacro = "http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find fishbot_description)/urdf/fishbot/common_inertia.xacro" />
   
    <!-- 声明执行器模块 声明名字为wheel_xacro，参数为wheel_name和xyz的宏 -->
    <xacro:macro name = "wheel_xacro" params = "wheel_name xyz">
        <link name="${wheel_name}_wheel_link">
        <!-- 部件外观描述 -->
            <visual>
                <!-- 沿自己几何中心的偏移与旋转量 -->
                <origin xyz="0 0 0.0" rpy="1.57079 0 0" />
                <!-- 几何形状 -->
                <geometry>
                <cylinder length="0.04" radius="0.032" />
                </geometry>
                <!-- 材质子标签 -->
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8" />
                </material>
            </visual>

            <collision>
                <!-- 沿自己几何中心的偏移与旋转量 -->
                <origin xyz="0 0 0.0" rpy="1.57079 0 0" />
                <!-- 几何形状 -->
                <geometry>
                <cylinder length="0.04" radius="0.032" />
                </geometry>
                <!-- 材质子标签 -->
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8" />
                </material>
            </collision>

            <xacro:cylinder_inertia m = "0.02" r = "0.032" h = "0.04" />
        </link>

        <joint name = "${wheel_name}_wheel_joint" type = "continuous">
        <parent link = "base_link" />
        <child link = "${wheel_name}_wheel_link" />
        <origin xyz = "${xyz}" />
        <axis xyz=" 0 1 0" />
        </joint>  

        <gazebo reference = "${wheel_name}_wheel_link">
            <material>Gazebo/Yellow</material>
            <!-- 摩擦系数 刚度系数 阻尼系数 -->
            <mu1 value = "20.0" />
            <mu2 value = "20.0" />
            <kp value = "1000000000.0" />
            <kd value = "1.0" />
        </gazebo>

    </xacro:macro>
    
</robot>